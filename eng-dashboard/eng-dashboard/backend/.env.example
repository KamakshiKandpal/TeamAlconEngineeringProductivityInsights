# Copy to .env and fill in — never commit the real .env file.

# GitLab
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx      # personal/project/group access token, read_api scope
GITLAB_PROJECT_IDS=12345678,23456789         # comma-separated numeric project IDs to sync
SYNC_WINDOW_HOURS=24                         # reconciliation lookback window for each sync run

# Database (production)
DATABASE_URL=postgres://user:password@localhost:5432/eng_dashboard

# API server
PORT=4000

# Optional AI insight generation
CLAUDE_API_KEY=your-claude-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
